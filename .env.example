# Minecraft server connection
MC_HOST=play.pathofendalor.net
MC_PORT=25565
MC_TIMEOUT_MS=5000

# Local status API
STATUS_API_PORT=8787
STATUS_CACHE_TTL_MS=10000
# Economy/SFTP refresh window (10 minutes)
ECONOMY_CACHE_TTL_MS=600000
# Optional: if set, frontend requests must send x-status-api-key header
STATUS_API_KEY=

# Optional AMP API source (if available in your Hostinger AMP setup)
AMP_STATUS_URL=
AMP_BEARER_TOKEN=

# Frontend video tutorial link (shown on Rules page)
VITE_INSTALL_TUTORIAL_YOUTUBE_URL=

# SFTP for EconomyCraft JSON
SFTP_HOST=
SFTP_PORT=22
SFTP_USERNAME=
# Option A: password auth
SFTP_PASSWORD=
# Option B: SSH key auth (prefer this)
SFTP_PRIVATE_KEY=
SFTP_PRIVATE_KEY_PATH=
SFTP_PASSPHRASE=
SFTP_TIMEOUT_MS=10000

# Absolute path to the EconomyCraft JSON file on the server
ECONOMY_JSON_PATH=

# Secure modpack download
MODPACK_FILE_PATH=
MODPACK_FILE_NAME=Pathofendalor-Modpack.zip
MODPACK_DOWNLOAD_SECRET=
# Default: 5 minutes
MODPACK_DOWNLOAD_TTL_MS=300000
